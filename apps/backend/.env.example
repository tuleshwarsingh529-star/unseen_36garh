# ─── CG Tourism Backend — Environment Configuration ────────────────────────
# Copy this file to .env and fill in your actual values.
# Never commit .env to git.

# ── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Find this in Supabase Project Settings -> Database -> Connection string (URI)
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres"

# ── Supabase Configuration (Optional for backend depending on Auth strategy) ──
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-never-share-this"

# ── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET="cg_tourism_jwt_secret_key_2026_bastar"
JWT_EXPIRES_IN="7d"

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000

# ── CORS (comma-separated allowed origins) ───────────────────────────────────
CORS_ALLOWED_ORIGINS="http://localhost:3000,https://cg-tourism.vercel.app"

# ── Redis (Remove or keep if using separate Render Redis for Queues) ────────
REDIS_URL="redis://localhost:6379"

# ── Node environment ─────────────────────────────────────────────────────────
NODE_ENV=development
